# LM Studio / OpenAI-compatible API.
# The Python default is http://127.0.0.1:1488/v1 for non-Docker runs.
# In Docker, use host.docker.internal so the app container can reach LM Studio on Windows Docker Desktop.
LLM_BASE_URL=http://host.docker.internal:1488/v1
LLM_MODEL=lmstudio-community/gemma-4-e4b-it
LLM_API_KEY=lm-studio

# Embeddings.
EMBEDDING_MODEL=jinaai/jina-embeddings-v3
# Optional; Jina v3 asymmetric retrieval. Leave unset for defaults, or set empty to disable.
# EMBEDDING_QUERY_TASK=retrieval.query
# EMBEDDING_PASSAGE_TASK=retrieval.passage
# Examples: cpu, cuda, mps. Leave blank for sentence-transformers auto-detection.
EMBEDDING_DEVICE=
# Docker: default image installs CPU-only PyTorch. For GPU use either:
#   docker compose -f docker-compose.yml -f docker-compose.gpu.yml up --build
# or set INSTALL_CUDA_TORCH=1 (CUDA 12.4 wheels), add `gpus: all` to the app service, and EMBEDDING_DEVICE=cuda.
# INSTALL_CUDA_TORCH=0

# Storage.
POSTGRES_PASSWORD=rag

# Indexing.
# Startup indexing: off by default. Index runs on startup only if Qdrant has no points,
# or set FORCE_REINDEX_ON_START=true, or set AUTO_INDEX=true (always run a sync check).
AUTO_INDEX=false
FORCE_REINDEX_ON_START=false

